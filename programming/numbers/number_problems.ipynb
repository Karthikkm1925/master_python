   ],
   "source": [
    "# Reverese given Integer Number\n",
    "num = int(input(\"Enter the Nuber :\\n\")) \n",
    "rev = 0\n",
    "while num !=0 :\n",
    "    rev = (rev*10) + (num%10)\n",
    "    num//=10\n",
    "print(rev) "
   ]
