   "source": [
    "num = int(input(\"Enter the number of terms: \"))\n",
    "print(\"You Entered\",num)\n",
    "a = 0\n",
    "b = 1\n",
    "print(\"Fibonacci series...\")\n",
    "for i in range(num):\n",
    "    print(a, end=\" \")\n",
    "    c = a + b\n",
    "    a = b\n",
    "    b = c"
   ]
